# Copy this file to .env.local and fill in real values.
# .env.local is gitignored. Never commit secrets.

# Public site metadata
NEXT_PUBLIC_SITE_URL=https://example.com

# Supabase public browser/auth config
NEXT_PUBLIC_SUPABASE_URL=https://example.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=replace-with-public-anon-key

# Supabase server-only key. Never prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=replace-with-server-only-service-role-key

# Admin access allowlist, comma-separated.
ADMIN_ALLOWED_EMAILS=admin@example.com

# Sentry monitoring. Leave empty to disable locally.
NEXT_PUBLIC_SENTRY_DSN=

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=

# ─── Calendly (optional) ──────────────────────────────────────────────────────
# Public booking page URL shown to users who select "Calendly" as contact method.
# This is a public link — safe to expose in the browser (NEXT_PUBLIC_ prefix intended).
# If empty, the booking form shows a "coming soon" message instead of the Calendly button.
NEXT_PUBLIC_CALENDLY_FREE_CALL_URL=

# Webhook signing key from Calendly dashboard (optional, recommended in prod).
# Server-side only — used to validate Calendly webhook authenticity.
# CALENDLY_WEBHOOK_SIGNING_KEY=your-signing-key
