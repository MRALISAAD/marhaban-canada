FROM node:20-alpine
WORKDIR /app

# Install dependencies only — source code comes from the bind mount at runtime
COPY package.json package-lock.json ./
RUN npm ci

# node_modules are preserved inside the container via a named Docker volume.
# The bind mount (.:/app) overlays the project source at runtime, while the
# named volume at /app/node_modules keeps the container's node_modules intact.
